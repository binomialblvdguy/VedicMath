<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true"
    tools:context=".ui.screens.fragments.CrossProductQuizFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="2dp">

            <TextView
                android:id="@+id/text_mode_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:text="Mode: Standard"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <Switch
                android:id="@+id/advancedModeSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textOff="Standard"
                android:textOn="Advanced"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvQuizTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Cross Product Quiz"
            android:textColor="#FFEB3B"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvQuizSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Practice spotting cross terms by observation."
            android:textColor="#BBBBBB"
            android:textSize="11sp"
            tools:text="Practice spotting cross terms by observation." />

        <TextView
            android:id="@+id/tvQuizScore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_neon_cyan"
            android:padding="10dp"
            android:textColor="#FFEB3B"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="Score: 2/3   Accuracy: 66%" />

        <TextView
            android:id="@+id/tvQuizTypeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Rule"
            android:textColor="#BBBBBB"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvQuizType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:background="@drawable/bg_neon_cyan"
            android:padding="10dp"
            android:textColor="#FFEB3B"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="Units Sum 10 / Tens Differ by 1" />

        <TextView
            android:id="@+id/tvQuizPromptLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Question"
            android:textColor="#BBBBBB"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvQuizPrompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:background="@drawable/bg_neon_cyan"
            android:padding="10dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            tools:text="Find only the cross term for 37 × 43" />

        <TextView
            android:id="@+id/tvQuizExplanationPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#BBBBBB"
            android:textSize="11sp"
            tools:text="Solve mentally, then enter only the cross term." />

        <EditText
            android:id="@+id/etCrossAnswer"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_neon_cyan"
            android:hint="Enter cross term"
            android:inputType="number"
            android:paddingHorizontal="10dp"
            android:paddingVertical="8dp"
            android:textColor="#FFEB3B"
            android:textColorHint="#666666"
            android:textSize="13sp"
            tools:text="37" />

        <LinearLayout
            android:id="@+id/rowButtonsTop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitAnswer"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:backgroundTint="#FFEB3B"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:text="Check"
                android:textAllCaps="false"
                android:textColor="#121212"
                android:textSize="10sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNextQuestion"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:text="Next"
                android:textAllCaps="false"
                android:textColor="#FFEB3B"
                android:textSize="10sp"
                app:strokeColor="#FFEB3B" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowButtonsBottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResetQuiz"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:text="Reset"
                android:textAllCaps="false"
                android:textColor="#FFEB3B"
                android:textSize="10sp"
                app:strokeColor="#FFEB3B" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackToCalculator"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:backgroundTint="#FFEB3B"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:text="Back"
                android:textAllCaps="false"
                android:textColor="#121212"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvQuizFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_step_card"
            android:padding="10dp"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            tools:text="Correct ✅&#10;Because the tens differ by 1 and the units add to 10, the cross term equals the smaller number: 37." />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>